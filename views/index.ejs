<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description"
    content="Look up CodeChef user ratings, global rank, and country rank for multiple users at once.">
  <title>CodeChef Rating Lookup</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <div class="bg-glow glow-1"></div>
  <div class="bg-glow glow-2"></div>
  <div class="bg-glow glow-3"></div>

  <main class="container">
    <!-- Hero Header -->
    <header class="hero">
      <div class="logo">
        <span class="logo-icon">⚡</span>
        <h1>CodeChef <span class="gradient-text">Rating Lookup</span></h1>
      </div>
      <p class="subtitle">Enter multiple CodeChef usernames to instantly view their rating, global rank, and country
        rank.</p>
    </header>

    <!-- Search Card -->
    <section class="card search-card">
      <form action="/lookup" method="POST" id="lookupForm">
        <label for="usernames" class="input-label">Enter Usernames</label>
        <p class="input-hint">Enter one username per line</p>
        <textarea name="usernames" id="usernames" rows="4" placeholder="e.g.
tourist
admin
codechef_user1" spellcheck="false"><%= usernames %></textarea>
        <button type="submit" id="lookupBtn" class="btn-primary">
          <span class="btn-icon">🔍</span>
          <span class="btn-text">Lookup Ratings</span>
          <span class="btn-loader" style="display:none;">
            <span class="spinner"></span> Fetching...
          </span>
        </button>
      </form>
    </section>

    <% if (error) { %>
      <div class="alert alert-error">
        <span class="alert-icon">⚠️</span>
        <span>
          <%= error %>
        </span>
      </div>
      <% } %>

        <% if (results && results.length> 0) { %>
          <!-- Results Card -->
          <section class="card results-card">
            <div class="results-header">
              <h2>📊 Results</h2>
              <span class="badge">
                <%= results.length %> user<%= results.length> 1 ? 's' : '' %>
              </span>
            </div>

            <div class="table-wrapper">
              <table id="resultsTable">
                <thead>
                  <tr>
                    <th>S.No</th>
                    <th>Username</th>
                    <th>Rating</th>
                    <th>Global Rank</th>
                    <th>Country Rank</th>
                    <th>Last Contest</th>
                    <th>Rating Change</th>
                  </tr>
                </thead>
                <tbody>
                  <% results.forEach((user, index)=> { %>
                    <tr class="<%= user.error ? 'row-error' : '' %>" style="animation-delay: <%= index * 0.05 %>s">
                      <td class="cell-sno">
                        <%= index + 1 %>
                      </td>
                      <td class="cell-username">
                        <a href="https://www.codechef.com/users/<%= user.username %>" target="_blank" rel="noopener">
                          <%= user.username %>
                        </a>
                        <% if (user.stars) { %>
                          <span class="stars">
                            <%= user.stars %>
                          </span>
                          <% } %>
                            <% if (user.error) { %>
                              <span class="error-tag">Not Found</span>
                              <% } %>
                      </td>
                      <td class="cell-rating">
                        <span class="rating-value">
                          <%= user.rating %>
                        </span>
                      </td>
                      <td class="cell-rank">
                        <%= user.globalRank %>
                      </td>
                      <td class="cell-rank">
                        <%= user.countryRank %>
                      </td>
                      <td class="cell-contest">
                        <% if (user.lastContest !=='N/A' ) { %>
                          <a href="https://www.codechef.com/<%= user.lastContest %>" target="_blank" rel="noopener"
                            class="contest-link">
                            <%= user.lastContest %>
                          </a>
                          <% } else { %>
                            N/A
                            <% } %>
                      </td>

                      <td class="cell-change">
                        <% if (user.ratingChange !=='N/A' ) { %>
                          <span class="change-badge change-<%= user.ratingChangeSign === '+' ? 'pos' : 'neg' %>">
                            <%= user.ratingChange %>
                          </span>
                          <% } else { %>
                            <span class="change-badge change-na">N/A</span>
                            <% } %>
                      </td>
                    </tr>
                    <% }) %>
                </tbody>
              </table>
            </div>
          </section>
          <% } %>
  </main>

  <footer class="footer">
    <p>Build by Purna Kunche &bull; Data sourced from CodeChef</p>
  </footer>

  <script>
    const form = document.getElementById('lookupForm');
    const btnText = document.querySelector('.btn-text');
    const btnLoader = document.querySelector('.btn-loader');
    const btn = document.getElementById('lookupBtn');

    form.addEventListener('submit', () => {
      btnText.style.display = 'none';
      btnLoader.style.display = 'inline-flex';
      btn.disabled = true;
      btn.classList.add('loading');
    });

    // Animate table rows on load
    document.querySelectorAll('#resultsTable tbody tr').forEach((row, i) => {
      row.style.animationDelay = `${i * 60}ms`;
    });
  </script>
</body>

</html>